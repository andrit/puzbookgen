    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx src/seed/import-csv.ts",
    "prebuild": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.16.0",
    "@puzzle-book/shared": "*",
    "csv-parse": "^5.5.6"
  },
  "devDependencies": {
    "prisma": "^5.16.0",
    "typescript": "*",
    "tsx": "*"
  }
}