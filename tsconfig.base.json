{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@puzzle-book/shared": ["packages/shared/dist/index"],
      "@puzzle-book/puzzle-generator": ["packages/puzzle-generator/dist/index"],
      "@puzzle-book/book-generator": ["packages/book-generator/dist/index"],
      "@puzzle-book/content-db": ["packages/content-db/dist/index"]
    }
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
