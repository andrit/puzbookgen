{
  "name": "@puzzle-book/web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite client",
    "build": "tsc && vite build client",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@puzzle-book/shared": "*",
    "@puzzle-book/puzzle-generator": "*",
    "@puzzle-book/book-generator": "*",
    "@puzzle-book/content-db": "*",
    "fastify": "^4.28.0",
    "@fastify/static": "^7.0.4",
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.0",
    "archiver": "^7.0.1"
  },
  "devDependencies": {
    "@types/node": "*",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "*",
    "tsx": "*",
    "vite": "^5.3.0"
  }
}